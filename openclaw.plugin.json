{
  "id": "codex-agent",
  "name": "Codex Agent",
  "description": "Invoke local Codex CLI from /codex command with project allowlist and verbatim output.",
  "version": "0.1.2",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "codexPath": {
        "type": "string",
        "description": "Full path to codex binary. Leave empty for auto-detection via PATH."
      },
      "defaultTimeoutSec": {
        "type": "integer",
        "minimum": 30,
        "maximum": 1800,
        "description": "Default timeout in seconds, default 600"
      },
      "noOutputTimeoutSec": {
        "type": "integer",
        "minimum": 10,
        "maximum": 600,
        "description": "No-output timeout in seconds, default 120"
      },
      "model": {
        "type": "string",
        "description": "Codex model override"
      },
      "sandbox": {
        "type": "string",
        "enum": [
          "read-only",
          "workspace-write",
          "danger-full-access"
        ],
        "description": "Codex sandbox mode, default workspace-write"
      },
      "skipGitRepoCheck": {
        "type": "boolean",
        "description": "Pass --skip-git-repo-check, default true"
      },
      "projects": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "description": "Project name to path mapping (allowlist)"
      },
      "maxConcurrent": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10,
        "description": "Maximum concurrent codex processes, default 3"
      },
      "enableAgentTool": {
        "type": "boolean",
        "description": "Register codex_agent tool for PI Agent fallback. Default false."
      },
      "remote": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "host": {
            "type": "string"
          },
          "user": {
            "type": "string"
          },
          "port": {
            "type": "integer"
          },
          "keyPath": {
            "type": "string"
          },
          "strictHostKeyChecking": {
            "type": "string",
            "enum": [
              "yes",
              "no",
              "accept-new"
            ]
          },
          "codexPath": {
            "type": "string"
          }
        },
        "required": [
          "host",
          "user"
        ]
      }
    }
  },
  "uiHints": {
    "codexPath": {
      "label": "Codex Path"
    },
    "defaultTimeoutSec": {
      "label": "Default Timeout (sec)"
    },
    "projects": {
      "label": "Project Mapping"
    },
    "maxConcurrent": {
      "label": "Max Concurrent"
    },
    "enableAgentTool": {
      "label": "Enable Agent Tool"
    }
  }
}
